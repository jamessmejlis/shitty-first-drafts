# Canonical site URL (drives metadataBase, sitemap, OG absolute URLs)
NEXT_PUBLIC_SITE_URL=https://ugly.marulho.co
# beehiiv public subscribe page, e.g. https://your-pub.beehiiv.com/subscribe.
# The signup form hands off here with the email prefilled; unset = honest no-op.
NEXT_PUBLIC_BEEHIIV_SUBSCRIBE_URL=

# Submissions go through GitHub Issues (the submit form opens a pre-filled issue),
# so no server-side keys are needed.
